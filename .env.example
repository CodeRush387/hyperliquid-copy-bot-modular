# One or more comma-separated leader wallets.
HRS_LEADER_ADDRESSES=0x0000000000000000000000000000000000000000

# Existing QuickNode HyperCore gRPC integration.
HC_GRPC_ENDPOINT=your-grpc-host:443
HC_GRPC_SERVER_NAME=your-grpc-host
HC_GRPC_TOKEN=YOUR_QUICKNODE_TOKEN

# Optional override for one-time startup HTTPS snapshots/history/meta.
# If omitted, https://HC_GRPC_SERVER_NAME/HC_GRPC_TOKEN/info is used.
# QUICKNODE_INFO_URL=https://your-quicknode-host/YOUR_QUICKNODE_TOKEN/info

# Observation-only is the safe default. Do not enable without explicit approval.
HRS_EXECUTION_ENABLED=false
HRS_ALLOCATION_GAP_PCT=3.0

# Required only when HRS_EXECUTION_ENABLED=true.
FOLLOWER_ADDRESS=0x0000000000000000000000000000000000000000
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
FIXED_NOTIONAL_USD=12
HRS_EXECUTION_CONFIRM_TIMEOUT_SECONDS=15
TESTNET=false
SLIPPAGE=0.05